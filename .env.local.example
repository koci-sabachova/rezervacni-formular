# Resend (transakční e-maily) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM="Rezervace Cobra & Informace <rezervace@barcobra.cz>"
EMAIL_TO=rezervace@barcobra.cz
EMAIL_REPLY_TO=rezervace@barcobra.cz

# Google Sheets API (catering menu)
# Service account email získáš v Google Cloud Console; sheet musíš s ním nasdílet (čtenář).
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE="Menu!A:I"

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Volitelné: vypnout spam ochranu v dev (pokud nemáš Turnstile klíč)
# DISABLE_TURNSTILE=1
